############################################################
# AMBIENTE
############################################################

NODE_ENV=production

############################################################
# SERVIDOR
############################################################

PORT=10000

############################################################
# CACHE GLOBAL
############################################################

# Tempo padrão do cache (minutos)
CACHE_TTL=10

# Cache da HOME (mais curto)
CACHE_TTL_HOME=2

# Cache de listas
CACHE_TTL_LIST=10

# Cache de detalhes
CACHE_TTL_DETAILS=30

############################################################
# RATE LIMIT (PROTEÇÃO)
############################################################

# Janela em minutos
RATE_LIMIT_WINDOW=15

# Máximo por IP
RATE_LIMIT_MAX=300

############################################################
# CORS
############################################################

# Em produção, se tiver domínio:
# https://seusite.com

CORS_ORIGIN=*

############################################################
# FONTES (SITE PAI)
############################################################

ANIME_BASE_URL=https://animefire.io/

############################################################
# CONTROLE DO SCRAPER
############################################################

# Quantidade máxima de scrapers simultâneos
SCRAPER_MAX_CONCURRENT=2

# Número máximo de tentativas
SCRAPER_MAX_RETRIES=2

############################################################
# TIMEOUTS
############################################################

SCRAPER_HTTP_TIMEOUT=20000
SCRAPER_BROWSER_TIMEOUT=25000

############################################################
# DELAY ENTRE REQUISIÇÕES
############################################################

SCRAPER_MIN_DELAY_MS=900
SCRAPER_MAX_DELAY_MS=2200

############################################################
# PLAYWRIGHT
############################################################

SCRAPER_PLAYWRIGHT_WAIT_MS=1500

############################################################
# LOGS
############################################################

LOG_LEVEL=info